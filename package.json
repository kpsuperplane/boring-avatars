{
  "name": "@kpsuperplane/boring-avatars",
  "description": "Deterministic Marble and Beam SVG avatars with expressive, state-driven React animation.",
  "homepage": "https://github.com/kpsuperplane/boring-avatars#readme",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kpsuperplane/boring-avatars.git"
  },
  "bugs": {
    "url": "https://github.com/kpsuperplane/boring-avatars/issues"
  },
  "keywords": [
    "avatar",
    "react",
    "svg",
    "animated avatar",
    "voice avatar",
    "marble avatar",
    "beam avatar"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.lib.json --emitDeclarationOnly",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
